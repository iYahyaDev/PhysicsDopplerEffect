  "physics": {
    "implementedModels": ["classical acoustic Doppler", "retarded-time wavefront display", "linear automatic source pass", "circular automatic source motion", "distance loudness gain", "police radar shift", "medical ultrasound Doppler", "relativistic astronomical redshift", "sound-vs-light comparison"],
    "equations": [
      {"name": "acoustic Doppler", "files": ["Scripts/doppler-engine.js", "Services/PhysicsCalculator.cs"], "formula": "fObserved = fEmit * (c - dot(observerVelocity,n)) / (c - dot(sourceVelocity,n))", "units": "Hz, m/s, meters", "status": "implemented in C# and JavaScript"},
      {"name": "sound speed from temperature", "files": ["Scripts/doppler-engine.js", "Services/PhysicsCalculator.cs"], "formula": "c = 331.3 + 0.606 * temperatureCelsius", "units": "m/s", "status": "implemented"},
      {"name": "distance gain", "files": ["Scripts/doppler-engine.js"], "formula": "gain = clamp(16 / max(distance,4), 0.025, 0.28)", "units": "dimensionless gain", "status": "implemented"},
      {"name": "linear kinematics", "files": ["Scripts/doppler-engine.js"], "formula": "x = startX + speed * elapsed; y = pathY; vx = speed until complete", "units": "meters, seconds, m/s", "status": "implemented"},
      {"name": "circular kinematics", "files": ["Scripts/doppler-engine.js"], "formula": "theta = theta0 + direction * omega * elapsed; x = cx + R cos(theta); y = cy + R sin(theta); vx = -direction R omega sin(theta); vy = direction R omega cos(theta)", "units": "meters, radians, seconds, m/s", "status": "implemented"},
      {"name": "police radar", "files": ["Scripts/applications.js"], "formula": "delta = 2 * transmitFrequency * speed / cLight", "units": "Hz, m/s", "status": "implemented"},
      {"name": "ultrasound Doppler", "files": ["Scripts/applications.js"], "formula": "delta = 2 * probeFrequency * bloodSpeed * cos(angle) / 1540", "units": "Hz, m/s", "status": "implemented"},
      {"name": "relativistic light Doppler", "files": ["Scripts/applications.js"], "formula": "freqRatio = sqrt((1 - beta)/(1 + beta)); lambdaRatio = 1 / freqRatio", "units": "dimensionless beta and ratio", "status": "implemented"}
    ],
    "assumptions": ["World coordinates are meters.", "Positive source radial velocity is motion along source-to-observer unit vector.", "Distance loudness affects audio gain, not frequency.", "Retarded-time sampling is used for observed metrics and wavefront display in the simulation."],
    "knownIssues": ["Fullscreen requires browser permission/runtime verification.", "Canvas labels are not fully localized.", "Subjective audio quality cannot be verified statically."]
  },
